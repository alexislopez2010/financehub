NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Server-only. Powers the one-time AI bill-history import (/api/forecast/analyze-history).
# Without it, the Forecast "Import history" flow returns a clear "not configured" error.
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Optional: override the model id used for history extraction (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6
